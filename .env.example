# Which data provider to use: "mock" | "getxapi" | "twitterapi"
# Leave as "mock" until you've signed up for a real key, the app runs fully
# end-to-end on realistic fake data so you can test everything right now.
TWITTER_API_PROVIDER=mock

# Fill these in once you sign up (see README "Going live" section)
GETXAPI_KEY=
TWITTERAPI_IO_KEY=

# Optional, only needed once you swap the file-based cache for Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Needed for the multilingual profile analysis (Turkish, Chinese,
# Portuguese, etc.). Without this, non-English posts are still scanned
# and scored, they just fall back to punctuation-only classification.
ANTHROPIC_API_KEY=

# Circle Wallets, for the "mint on testnet" button. Get these from the
# Circle Developer Console (console.circle.com). See README "Circle
# setup" section for the full walkthrough.
CIRCLE_API_KEY=
CIRCLE_APP_ID=

# Circle Contracts, for the badge NFT itself. Only needed after you've
# deployed the badge contract once via the Console's Templates tab.
CIRCLE_ENTITY_SECRET=
CIRCLE_BADGE_CONTRACT_ADDRESS=
CIRCLE_ADMIN_WALLET_ID=

